<poml>
    <task>
        Generate a DuckDB query that calculates the time difference between consecutive messages 
        in the topic {{topic}}.  
        <stepwise-instructions>
            <list>
                <item>
                    Verify that the robolog file exists at the path: {{robolog_path}}.
                </item>
                <item>
                    Use Bagel’s `read_metadata` MCP tool to extract and understand the
                    robolog’s metadata.
                </item>
                <item>
                    Use Bagel’s `describe_topics` MCP tool to retrieve:
                     Timestamp column name of the topic table. Which should be timestamp_seconds.
                     The topic table name
                </item>
                <item>
                    Generate a DuckDB SQL query that calculates the difference between consective 
                    messages in the topic. Use the timestamp column name from the previous step for 
                    this.
                </item>
                <item>
                    Execute the SQL query using Bagel’s `query_topic_messages` MCP tool.
                </item>
                <item>
                    If the query output is too large, paginate by setting `start_seconds` and
                    `end_seconds` in the `query_topic_messages` tool.
                </item>
                <item>
                    Summarize and explain the query results in plain language for the user.
                </item>
            </list>
        </stepwise-instructions>
        <example>
            <input>
                User's prompt: "What is the latency of IMU messages?"
            </input>
            <output>
                <code lang="sql">
                    SELECT
                        timestamp_seconds,
                        timestamp_seconds - LAG(timestamp_seconds) OVER (ORDER BY timestamp_seconds) AS latency
                    FROM /imu
                </code>
            </output>
        </example>
    </task>
    <output-format>
        Respond with a DuckDB SQL query without additional characters or punctuations.
    </output-format>
</poml>
